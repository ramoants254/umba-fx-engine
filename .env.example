# PostgreSQL Database Configuration
POSTGRES_DB=fx_engine
POSTGRES_USER=fx_user
POSTGRES_PASSWORD=your_secure_password_here

# Application Config (prefix FX_ matches Settings class prefix)
FX_DATABASE_URL=postgresql://fx_user:your_secure_password_here@postgres:5432/fx_engine
FX_RATE_API_KEY=your_rates_api_key_here
